APP_NAME=docops-backend
APP_ENV=local
DATABASE_URL=postgresql+psycopg://docops:docops@localhost:5432/docops
AWS_REGION=us-east-1
AWS_S3_BUCKET=docops-documents-local
AWS_S3_ENDPOINT_URL=http://localhost:9000
AWS_S3_PUBLIC_ENDPOINT_URL=http://localhost:9000
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_S3_FORCE_PATH_STYLE=true
AWS_SQS_QUEUE_URL=http://localhost:4566/000000000000/docops-processing
AWS_SQS_ENDPOINT_URL=http://localhost:4566
PRESIGNED_URL_TTL_SECONDS=900
MAX_UPLOAD_SIZE_BYTES=10485760
ALLOWED_CONTENT_TYPES=application/pdf,text/plain,text/markdown,text/csv,application/json
CORS_ALLOWED_ORIGINS=http://localhost:5173
AUTH_TRUST_HEADERS=true
DEV_USER_ID=00000000-0000-0000-0000-000000000001
DEV_USER_EMAIL=demo@docops.local
DEV_USER_NAME=Demo User
